{
    "name": "redreport/app",
    "type": "project",
    "description": "Sistema de gestion de reportes, clientes y usuarios",
    "authors": [
        {
            "name": "RedReport",
            "email": "admin@redreport.com"
        }
    ],
    "require": {
        "php": "8.3",
        "dompdf/dompdf": "^2.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7"
    },
    "scripts": {
        "lint": "phpcs --standard=PSR12 --exclude=Generic.Files.LineLength app/ clientes/ login/ usuarios/"
    },
    "config": {
        "optimize-autoloader": true
    }
}
